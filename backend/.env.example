# Butterbase — get from dashboard (butterbase.ai)
BUTTERBASE_APP_ID=your-app-id
BUTTERBASE_API_URL=https://api.butterbase.ai
BUTTERBASE_ANON_KEY=your-anon-key
BUTTERBASE_SERVICE_KEY=your-service-key

# Neo4j — used by the deployed Butterbase Functions (Aura HTTP Query API v2,
# no bolt). Full URL as Aura hands it out, e.g.
# https://<dbid>.databases.neo4j.io/db/<dbid>/query/v2 — used as-is, not built
# up from pieces.
NEO4J_QUERY_URL=https://your-instance.databases.neo4j.io/db/your-instance/query/v2
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password

# Neo4j — bolt connection for local scripts only (backend/src/neo4j/*.ts:
# seed.ts, test-connection.ts). Same instance, different protocol/port.
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_DATABASE=neo4j

# Daytona — Ramiz fills these in
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_API_KEY=your-daytona-key

# RocketRide — orchestrator between Scout and Analyst, must be deployed to
# RocketRide Cloud (cloud.rocketride.ai), not just local/Docker.
# trigger-analyze calls this instead of hitting Daytona directly.
ROCKETRIDE_PIPELINE_URL=
