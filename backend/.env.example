# Butterbase — get from dashboard (butterbase.ai)
BUTTERBASE_APP_ID=your-app-id
BUTTERBASE_API_URL=https://api.butterbase.ai
BUTTERBASE_ANON_KEY=your-anon-key
BUTTERBASE_SERVICE_KEY=your-service-key

# Neo4j — used by the deployed Butterbase Functions (HTTP Query API, no bolt)
NEO4J_HTTP_URL=https://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password

# Neo4j — bolt connection for local scripts only (backend/src/neo4j/*.ts:
# seed.ts, test-connection.ts). Same instance, different protocol/port.
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_DATABASE=neo4j

# Daytona — Ramiz fills these in
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_API_KEY=your-daytona-key

# LLM (optional, Nebius)
NEBIUS_API_KEY=
