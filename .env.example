NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
NEO4J_DATABASE=
DAYTONA_API_KEY=
BUTTERBASE_APP_ID=
NEBIUS_API_KEY=

# RocketRide platform auth (extension/SDK -> cloud.rocketride.ai).
ROCKETRIDE_URI=https://api.rocketride.ai
ROCKETRIDE_APIKEY=your-rocketride-platform-key-here

# constructor-pipeline.pipe (RocketRide Cloud) — substituted into the pipe
# file's ${ROCKETRIDE_*} placeholders at deploy time. Powers ONLY the
# orchestrator relay agent inside the pipeline — unrelated to Scout/Analyst.
ROCKETRIDE_MINIMAX_KEY=your-minimax-api-key-here
# Daytona job server tunnel — POST /run. Update if the tunnel restarts.
ROCKETRIDE_DAYTONA_URL=https://your-tunnel.example/run
# Confirmed via Butterbase MCP manage_function(list).
ROCKETRIDE_TRIGGER_SCOUT_URL=https://api.butterbase.ai/v1/app_c6q2usx31f76/fn/trigger-scout
# trigger-scout is deployed auth:'none' (see docs/ROCKETRIDE_REQUIREMENTS.md)
# so this currently isn't required by the pipeline. Kept for future use.
ROCKETRIDE_BUTTERBASE_KEY=your-butterbase-service-key-here
